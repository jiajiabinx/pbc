# Copy to .env for local dev (never commit .env — it holds secrets).

# --- LLM access ---------------------------------------------------------------
# Anthropic API key (the models.py client reads ANTHROPIC_API_KEY / _AUTH_TOKEN).
ANTHROPIC_API_KEY=sk-ant-...
# If you route Anthropic calls through a gateway (e.g. OpenRouter), set the base
# URL and use that provider's key instead:
# ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_API_KEY=sk-or-v1-...

# --- Database -----------------------------------------------------------------
# Leave DATABASE_URL unset to use a local SQLite file (data/pbc.db).
# Set it to your shared Postgres to persist there. Every table is auto-prefixed
# with pbc_ so it won't clash with other apps sharing that instance.
# Railway provides this variable automatically when you attach a Postgres plugin.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional: override the table prefix (default: pbc_).
# PBC_TABLE_PREFIX=pbc_
